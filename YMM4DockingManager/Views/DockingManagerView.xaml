<!-- 全パネル一覧・全解除・自動復元。ロジックは DockingManagerViewModel。 -->
<UserControl x:Class="YMM4DockingManager.Views.DockingManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:YMM4DockingManager.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="520"
             d:DataContext="{d:DesignInstance Type=vm:DockingManagerViewModel}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Docking Manager" FontWeight="Bold" FontSize="16" />
            <TextBlock Text="Ctrl + 外部アプリのタイトルバーをドラッグして、Dock 01〜10 のパネル内で離すとアタッチします。"
                       Opacity="0.8" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                Padding="8"
                Margin="0,0,0,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="自動復元" Command="{Binding RestoreCommand}" Padding="10,4" Margin="0,0,6,0"/>
                    <Button Content="全解除" Command="{Binding DetachAllCommand}" Padding="10,4"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Panels}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PanelRowViewModel}">
                        <Border BorderBrush="#22000000" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding AttachedName}" />
                                    <TextBlock Text="{Binding Status}" Opacity="0.75" />
                                </StackPanel>
                                <Button Grid.Column="2" Content="解除" Command="{Binding DetachCommand}" Padding="10,3"
                                        IsEnabled="{Binding Enabled}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>

